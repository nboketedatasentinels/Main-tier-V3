{
  "name": "t4l-tier-website",
  "version": "1.0.0",
  "description": "Transformation 4 Leaders - Leadership Development Platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "clean:vite": "rm -rf node_modules/.vite .cache dist build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "tsc --noEmit",
    "qa": "npm run lint && npm run typecheck && npm run build",
    "test": "npm run qa",
    "diagnose:partner-orgs": "node scripts/diagnose-partner-org-mismatch.mjs",
    "fix:partner-orgs": "node scripts/fix-user-organization-assignments.mjs",
    "fix:partner-orgs:dry-run": "node scripts/fix-user-organization-assignments.mjs --dry-run"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.2.4",
    "@chakra-ui/react": "^2.10.9",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@lottiefiles/dotlottie-react": "^0.17.13",
    "@stripe/stripe-js": "^2.4.0",
    "@vercel/speed-insights": "^1.3.1",
    "canvas-confetti": "^1.9.2",
    "date-fns": "^3.0.6",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.4.0",
    "framer-motion": "^10.18.0",
    "lucide-react": "^0.309.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.3",
    "recharts": "^2.10.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.6.4",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.2.1",
    "autoprefixer": "^10.4.17",
    "dotenv": "^17.2.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.33",
    "prettier": "^3.2.4",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.1"
  },
  "keywords": [
    "leadership",
    "transformation",
    "development",
    "gamification"
  ],
  "author": "T4L",
  "license": "MIT"
}
