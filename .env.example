# Environment Variables
# Copy this file to .env and fill in your actual values

# Supabase (browser client: native Supabase Auth - email/password + Google)
# The anon/public key is safe to expose client-side; it relies on RLS.
#   VITE_SUPABASE_URL      : Supabase dashboard, Settings, API, Project URL
#   VITE_SUPABASE_ANON_KEY : Supabase dashboard, Settings, API, anon public key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# Firebase Configuration (legacy; auth has moved to Supabase)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# Stripe Configuration
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key_here

# App Configuration
VITE_APP_BASE_URL=https://tier.t4leader.com

# Admin Bootstrap
# A comma-separated list of emails for users who should be granted Super Admin role on their first login.
# Example: VITE_BOOTSTRAP_ADMIN_EMAILS=admin1@example.com,admin2@example.com
VITE_BOOTSTRAP_ADMIN_EMAILS=

# Enable real-time profile updates for onSnapshot listeners (e.g., AuthContext, partner dashboards, and leaderboard views).
# Set to "true" to keep organization assignments synchronized without manual refresh.
VITE_ENABLE_PROFILE_REALTIME=true

# Feature Flags
# Enable parallel tracking for the new window-based progress system.
# When true, the app will write to both weeklyProgress and windowProgress collections.
VITE_FEATURE_FLAG_PARALLEL_WINDOW_TRACKING=false
