rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function normalizeRoleValue(rawRole) {
      return !(rawRole is string)
        ? ''
        : (
          rawRole.lower().matches('^\\s*super[\\s_-]*admin\\s*$') || rawRole.lower().matches('^\\s*super\\s*$')
            ? 'super_admin'
            : (
              rawRole.lower().matches('^\\s*(partner|admin|administrator|company[\\s_-]*admin)\\s*$')
                ? 'partner'
                : (
                  rawRole.lower().matches('^\\s*mentor\\s*$')
                    ? 'mentor'
                    : (
                      rawRole.lower().matches('^\\s*ambassador\\s*$')
                        ? 'ambassador'
                        : (
                          rawRole.lower().matches('^\\s*paid[\\s_-]*member\\s*$')
                            ? 'paid_member'
                            : (
                              rawRole.lower().matches('^\\s*free[\\s_-]*user\\s*$')
                                ? 'free_user'
                                : (
                                  rawRole.lower().matches('^\\s*user\\s*$')
                                    ? 'user'
                                    : ''
                                )
                            )
                        )
                    )
                )
            )
        );
    }

    function getRoleFromToken() {
      return !isAuthenticated()
        ? ''
        : (
          request.auth.token.admin == true || request.auth.token.super_admin == true || request.auth.token.superAdmin == true
            ? 'super_admin'
            : (
              request.auth.token.partner == true || request.auth.token.company_admin == true
                ? 'partner'
                : (
                  request.auth.token.role is string
                    ? normalizeRoleValue(request.auth.token.role)
                    : (
                      request.auth.token.claimsRole is string
                        ? normalizeRoleValue(request.auth.token.claimsRole)
                        : (
                          request.auth.token.customRole is string
                            ? normalizeRoleValue(request.auth.token.customRole)
                            : ''
                        )
                    )
                )
            )
        );
    }

    function getRoleFromUsersDoc() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let userData = isAuthenticated() ? get(userPath).data : null;
      return userData == null
        ? ''
        : normalizeRoleValue(
          userData.get(
            'role',
            userData.get(
              'userRole',
              userData.get('claimsRole', userData.get('customRole', userData.get('accountType', '')))
            )
          )
        );
    }

    function getRoleFromProfilesDoc() {
      let profilePath = /databases/$(database)/documents/profiles/$(request.auth.uid);
      let profileData = isAuthenticated() ? get(profilePath).data : null;
      return profileData == null
        ? ''
        : normalizeRoleValue(
          profileData.get(
            'role',
            profileData.get(
              'userRole',
              profileData.get('claimsRole', profileData.get('customRole', profileData.get('accountType', '')))
            )
          )
        );
    }

    function getUserRole() {
      let tokenRole = getRoleFromToken();
      let usersRole = getRoleFromUsersDoc();
      let profilesRole = getRoleFromProfilesDoc();
      return usersRole != ''
        ? usersRole
        : (profilesRole != ''
          ? profilesRole
          : tokenRole);
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }

    function isPartner() {
      return isAuthenticated() && getUserRole() == 'partner';
    }

    function isPartnerOrAdmin() {
      return isAuthenticated() && getUserRole() in ['partner', 'super_admin'];
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function getUserStringField(fieldName) {
      let usersDoc = isAuthenticated()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid))
        : null;
      let profilesDoc = isAuthenticated()
        ? get(/databases/$(database)/documents/profiles/$(request.auth.uid))
        : null;
      return usersDoc != null && usersDoc.data != null
        ? usersDoc.data.get(fieldName, '')
        : (
          profilesDoc != null && profilesDoc.data != null
            ? profilesDoc.data.get(fieldName, '')
            : ''
        );
    }

    function getUserCompanyId() {
      return getUserStringField('companyId');
    }

    function getUserCompanyCode() {
      return getUserStringField('companyCode');
    }

    function getUserVillageId() {
      return getUserStringField('villageId');
    }

    function getUserClusterId() {
      return getUserStringField('clusterId');
    }

    function orgMatchesCurrentUser(orgValue) {
      return isNonEmptyString(orgValue) && (
        (isNonEmptyString(getUserCompanyId()) && orgValue == getUserCompanyId()) ||
        (isNonEmptyString(getUserCompanyCode()) && orgValue == getUserCompanyCode())
      );
    }

    function isOrgMember(orgId) {
      return isAuthenticated() && orgMatchesCurrentUser(orgId);
    }

    function isOrgScopedData(data) {
      return data is map && (
        orgMatchesCurrentUser(data.orgId) ||
        orgMatchesCurrentUser(data.organizationId) ||
        orgMatchesCurrentUser(data.companyId) ||
        orgMatchesCurrentUser(data.companyCode)
      );
    }

    function isUserReferenced(data) {
      return isAuthenticated() && data is map && (
        data.userId == request.auth.uid ||
        data.user_id == request.auth.uid ||
        data.uid == request.auth.uid ||
        data.mentorId == request.auth.uid ||
        data.mentor_id == request.auth.uid ||
        data.partnerId == request.auth.uid ||
        data.partner_id == request.auth.uid
      );
    }

    function isValidPartnerAssignment(assignment) {
      return assignment is map
        && assignment.keys().hasOnly(['organizationId', 'companyCode', 'status'])
        && isNonEmptyString(assignment.organizationId)
        && isNonEmptyString(assignment.companyCode)
        && (!('status' in assignment) || assignment.status in ['active', 'watch', 'paused', 'inactive']);
    }

    function hasValidPartnerAssignments(data) {
      return !('assignedOrganizations' in data)
        || (data.assignedOrganizations is list
          && data.assignedOrganizations.all(assignment, isValidPartnerAssignment(assignment)));
    }

    function hasParticipantsList(data) {
      return data.keys().hasAll(['participants']) && data.participants is list;
    }

    function listHasUid(listValue, uid) {
      return listValue is list && uid in listValue;
    }

    function hasPeerSessionRequestFields(data) {
      return data.keys().hasAll(['fromUserId', 'toUserId']);
    }

    function isWeeklyMatchOwner(data) {
      return isAuthenticated() && data is map && (
        request.auth.uid == data.user_id ||
        request.auth.uid == data.userId
      );
    }

    function isWeeklyMatchParticipant(matchId) {
      return isAuthenticated() && (
        matchId.matches(request.auth.uid + '-.*') ||
        (resource != null && (
          request.auth.uid == resource.data.user_id ||
          request.auth.uid == resource.data.userId ||
          request.auth.uid == resource.data.user1_id ||
          request.auth.uid == resource.data.user2_id ||
          request.auth.uid == resource.data.peer_id ||
          request.auth.uid == resource.data.peerId
        ))
      );
    }

    function isVillageCreator(villageId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/villages/$(villageId))
        && get(/databases/$(database)/documents/villages/$(villageId)).data.creatorId == request.auth.uid;
    }

    function isVillageMember(villageId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/villages/$(villageId))
        && listHasUid(
          get(/databases/$(database)/documents/villages/$(villageId)).data.memberIds,
          request.auth.uid
        );
    }

    function isInvitationInvitee(invite) {
      return isAuthenticated()
        && (
          (!('email' in invite) || invite.email == null) ||
          invite.email == request.auth.token.email
        );
    }

    function isOrganizationCodeLookup() {
      return request.query != null
        && request.query.where.size() == 1
        && (
          request.query.where[0].fieldPath == 'code' ||
          request.query.where[0].field == 'code'
        )
        && request.query.where[0].op == '=='
        && request.query.limit != null
        && request.query.limit <= 1;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        (isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == 'user'))
      );
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])))
      );
      allow delete: if isSuperAdmin();
    }

    // Profiles collection
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        (isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == 'user'))
      );
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])))
      );
      allow delete: if isSuperAdmin();
    }

    // Engagement monitoring collections (admin only)
    match /user_engagement_scores/{scoreId} {
      allow read: if isPartnerOrAdmin();
      allow write: if isSuperAdmin();
    }

    match /engagement_trends/{trendId} {
      allow read: if isPartnerOrAdmin();
      allow write: if isSuperAdmin();
    }

    match /profiles/{userId}/engagement_history/{entryId} {
      allow read: if isPartnerOrAdmin();
      allow write: if isSuperAdmin();
    }

    match /profiles/{userId}/recent_activity/{entryId} {
      allow read: if isPartnerOrAdmin();
      allow write: if isSuperAdmin();
    }

    // Platform-wide configuration
    match /platform_config/{configId} {
      allow read: if isPartnerOrAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    // Referral codes collection
    match /referralCodes/{codeId} {
      // Anyone can read to validate codes during signup
      allow read: if true;
      // Only authenticated users can create their own referral code
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid;
      // Only owner or admin can update
      allow update: if isOwner(request.resource.data.uid) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Referrals collection
    match /referrals/{referralId} {
      // Referrer can read their own referrals, referred user can read their own record
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.referrerUid ||
        request.auth.uid == resource.data.referredUid ||
        isPartnerOrAdmin()
      );
      // Only server (Cloud Functions) should create referrals
      // Client can create if the referredUid matches the auth user
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.referredUid;
      // Only Cloud Functions (via admin SDK) should update referrals
      // Restrict client-side updates
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Points ledger collection
    match /pointsLedger/{entryId} {
      // Allow get by docId prefix (to support transaction.get on non-existent docs)
      allow get: if isAuthenticated() && (
        entryId.matches(request.auth.uid + '__.*') ||
        isPartnerOrAdmin()
      );
      // Allow list only when query is constrained to uid == request.auth.uid
      allow list: if isAuthenticated() && (
        resource.data.uid == request.auth.uid ||
        isPartnerOrAdmin()
      );
      // Allow create only for owner docId + uid match
      allow create: if isAuthenticated() && (
        (request.resource.data.uid == request.auth.uid && entryId.matches(request.auth.uid + '__.*')) ||
        isPartnerOrAdmin()
      );
      // Only admins can update/delete ledger entries
      allow update, delete: if isPartnerOrAdmin();
    }

    // Weekly progress collection
    match /weeklyProgress/{progressId} {
      allow get: if isAuthenticated() && (
        progressId.matches(request.auth.uid + '__.*') ||
        isPartnerOrAdmin()
      );
      allow list: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        resource.data.uid == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
      allow create, update: if isAuthenticated() && (
        progressId.matches(request.auth.uid + '__.*') ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Window progress collection
    match /windowProgress/{progressId} {
      allow get: if isAuthenticated() && (
        progressId.matches(request.auth.uid + '__.*') ||
        isPartnerOrAdmin()
      );
      allow list: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        resource.data.uid == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
      allow create, update: if isAuthenticated() && (
        progressId.matches(request.auth.uid + '__.*') ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Points transactions collection (for leaderboards)
    match /points_transactions/{transactionId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        request.auth.uid == resource.data.userId ||
        ((isNonEmptyString(resource.data.companyId) &&
          isNonEmptyString(getUserCompanyId()) &&
          resource.data.companyId == getUserCompanyId()) ||
         (isNonEmptyString(resource.data.companyCode) &&
          isNonEmptyString(getUserCompanyCode()) &&
          resource.data.companyCode == getUserCompanyCode())) ||
        (isNonEmptyString(resource.data.villageId) &&
         isNonEmptyString(getUserVillageId()) &&
         resource.data.villageId == getUserVillageId()) ||
        (isNonEmptyString(resource.data.clusterId) &&
         isNonEmptyString(getUserClusterId()) &&
         resource.data.clusterId == getUserClusterId())
      );
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        isPartnerOrAdmin()
      );
      allow update, delete: if isPartnerOrAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.user_id;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.user_id;
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isSuperAdmin()
      );
    }

    // Weekly target alerts
    match /weekly_target_alerts/{alertId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Organizations collection
    match /organizations/{orgId} {
      allow read: if isAuthenticated() || isOrganizationCodeLookup();
      allow create, update, delete: if isPartnerOrAdmin();
    }

    // Points verification requests
    match /points_verification_requests/{requestId} {
      // Allow owner doc-id lookups so transaction.get works for first-time submissions.
      allow get: if isAuthenticated() && (
        requestId.matches(request.auth.uid + '__.*') ||
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow list: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow update: if (
        isPartnerOrAdmin() && (
          resource.data.user_id != request.auth.uid || isSuperAdmin()
        )
      ) || (
        isAuthenticated() &&
        request.auth.uid == resource.data.user_id &&
        request.resource.data.user_id == resource.data.user_id &&
        request.resource.data.status == 'pending'
      );
      allow delete: if isSuperAdmin();
    }

    // Upgrade requests
    match /upgrade_requests/{requestId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Admin notifications
    match /admin_notifications/{notificationId} {
      allow read: if isPartnerOrAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    // Admin actions collection (for secure, auditable updates)
    match /admin_actions/{actionId} {
      allow read: if isPartnerOrAdmin();
      allow create: if isPartnerOrAdmin() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false; // Immutable log
    }

    // Interventions collection
    match /interventions/{interventionId} {
      allow read: if isPartnerOrAdmin();
      allow create: if isPartnerOrAdmin() && (
        isSuperAdmin() ||
        (request.resource.data.partner_id is string && request.resource.data.partner_id == request.auth.uid)
      );
      allow update: if isPartnerOrAdmin() && (
        isSuperAdmin() ||
        (resource.data.partner_id is string && resource.data.partner_id == request.auth.uid)
      );
      allow delete: if isSuperAdmin();
    }

    // Villages collection
    match /villages/{villageId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin()
        || (
          isAuthenticated()
          && request.resource.data.creatorId == request.auth.uid
          && listHasUid(request.resource.data.memberIds, request.auth.uid)
        );
      allow update: if isPartnerOrAdmin()
        || (
          isAuthenticated()
          && resource.data.creatorId == request.auth.uid
          && request.resource.data.creatorId == resource.data.creatorId
          && request.resource.data.memberCount <= 10
        );
      allow delete: if isPartnerOrAdmin();
    }

    // Village invitations collection
    match /village_invitations/{invitationId} {
      allow read: if isAuthenticated() && (
        isVillageCreator(resource.data.villageId) ||
        isVillageMember(resource.data.villageId) ||
        isInvitationInvitee(resource.data)
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        (
          (isVillageCreator(request.resource.data.villageId) || isVillageMember(request.resource.data.villageId))
          && request.resource.data.invitedBy == request.auth.uid
        )
      );
      allow update: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isVillageCreator(resource.data.villageId) ||
        (isVillageMember(resource.data.villageId) && request.auth.uid == resource.data.invitedBy) ||
        (isInvitationInvitee(resource.data)
          && request.resource.data.status in ['accepted', 'declined'])
      );
      allow delete: if isPartnerOrAdmin();
    }

    // Clusters collection
    match /clusters/{clusterId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isPartnerOrAdmin();
    }

    // Challenges collection
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.participants ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Peer matching collections
    match /peer_weekly_matches/{matchId} {
      allow get: if isWeeklyMatchParticipant(matchId) || isPartnerOrAdmin();
      allow list: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        (
          resource.data.user_id == request.auth.uid ||
          resource.data.userId == request.auth.uid ||
          resource.data.user1_id == request.auth.uid ||
          resource.data.user2_id == request.auth.uid ||
          resource.data.peer_id == request.auth.uid ||
          resource.data.peerId == request.auth.uid
        )
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.user_id ||
        request.auth.uid == request.resource.data.userId
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.user1_id ||
        request.auth.uid == resource.data.user2_id ||
        request.auth.uid == resource.data.peer_id ||
        request.auth.uid == resource.data.peerId ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Peer sessions
    match /peer_sessions/{sessionId} {
      allow read: if isAuthenticated() && (
        listHasUid(resource.data.participants, request.auth.uid) ||
        listHasUid(resource.data.participantIds, request.auth.uid) ||
        listHasUid(resource.data.participant_ids, request.auth.uid) ||
        request.auth.uid == resource.data.createdBy ||
        request.auth.uid == resource.data.creatorId ||
        request.auth.uid == resource.data.created_by ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        listHasUid(resource.data.participants, request.auth.uid) ||
        listHasUid(resource.data.participantIds, request.auth.uid) ||
        listHasUid(resource.data.participant_ids, request.auth.uid) ||
        request.auth.uid == resource.data.createdBy ||
        request.auth.uid == resource.data.creatorId ||
        request.auth.uid == resource.data.created_by ||
        isPartnerOrAdmin()
      );
      allow delete: if isPartnerOrAdmin();
    }

    // Mentorship sessions
    match /mentorship_sessions/{sessionId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.learner_id ||
        request.auth.uid == resource.data.learnerId ||
        request.auth.uid == resource.data.mentor_id ||
        request.auth.uid == resource.data.mentorId ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.learner_id ||
        request.auth.uid == request.resource.data.learnerId ||
        request.auth.uid == request.resource.data.mentor_id ||
        request.auth.uid == request.resource.data.mentorId ||
        isPartnerOrAdmin()
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.learner_id ||
        request.auth.uid == resource.data.learnerId ||
        request.auth.uid == resource.data.mentor_id ||
        request.auth.uid == resource.data.mentorId ||
        isPartnerOrAdmin()
      );
      allow delete: if isPartnerOrAdmin();
    }

    // Peer session requests/invitations
    match /peer_session_requests/{requestId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.fromUserId ||
        request.auth.uid == resource.data.toUserId ||
        request.auth.uid == resource.data.from_user_id ||
        request.auth.uid == resource.data.to_user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.fromUserId ||
        request.auth.uid == request.resource.data.from_user_id
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.fromUserId ||
        request.auth.uid == resource.data.toUserId ||
        request.auth.uid == resource.data.from_user_id ||
        request.auth.uid == resource.data.to_user_id ||
        isPartnerOrAdmin()
      );
      allow delete: if isPartnerOrAdmin();
    }

    // Support assignments
    match /support_assignments/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isPartnerOrAdmin()
      );
      allow create, update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Peer matches
    match /peer_matches/{matchId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Weekly habits
    match /weekly_habits/{habitId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Inspiration quotes
    match /inspiration_quotes/{quoteId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Impact logs collection
    match /impact_logs/{logId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        (isNonEmptyString(resource.data.companyId) &&
         isNonEmptyString(getUserCompanyId()) &&
         resource.data.companyId == getUserCompanyId()) ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.user_id ||
        request.auth.uid == request.resource.data.userId ||
        isPartnerOrAdmin()
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        isPartnerOrAdmin()
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        isSuperAdmin()
      );
    }

    // Badges collection
    match /badges/{badgeId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // User badges collection (camelCase)
    match /userBadges/{badgeAwardId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // User badges collection (snake_case)
    match /user_badges/{badgeAwardId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // Courses collection
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();
    }

    // Organization courses collection
    match /organization_courses/{courseId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isPartnerOrAdmin();
    }

    // Nudge templates
    match /nudge_templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Nudges sent
    match /nudges_sent/{nudgeId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isPartnerOrAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // Journey configs
    match /journey_configs/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Activity catalog
    match /activity_catalog/{activityId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Events collection
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // User courses collection
    match /user_courses/{courseId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // System health alerts
    match /system_health_alerts/{alertId} {
      allow read: if isPartnerOrAdmin();
      allow write: if isSuperAdmin();
    }

    // Task notifications
    match /task_notifications/{taskId} {
      allow read: if isPartnerOrAdmin();
      allow write: if isSuperAdmin();
    }

    // Admin activity log
    match /admin_activity_log/{entryId} {
      allow read: if isPartnerOrAdmin();
      // Allow Partner/Super Admin clients to write audit logs with verified attribution.
      allow create: if isPartnerOrAdmin()
        && request.resource.data.createdBy == request.auth.uid
        && (!('createdAt' in request.resource.data) || request.resource.data.createdAt == request.time);
      allow update, delete: if isSuperAdmin();
    }

    // User profile access audit logs
    match /profile_access_logs/{entryId} {
      allow read: if isPartnerOrAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.viewerId == request.auth.uid
        && request.resource.data.targetUserId is string
        && request.resource.data.allowed is bool
        && (!('viewerRole' in request.resource.data) || request.resource.data.viewerRole is string)
        && (!('reason' in request.resource.data) || request.resource.data.reason is string)
        && (!('route' in request.resource.data) || request.resource.data.route is string)
        && (!('createdAt' in request.resource.data) || request.resource.data.createdAt == request.time);
      allow update, delete: if false;
    }

    // Points verifications collection
    match /points_verifications/{verificationId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.user_id == request.auth.uid ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.user_id == request.auth.uid
      );
      allow update, delete: if isSuperAdmin();
    }


    // Partner organizations collection
    match /partner_organizations/{partnerOrgId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Registrations collection
    match /registrations/{registrationId} {
      allow read: if isAuthenticated();
      allow create: if true;  // Allow during signup
      allow update: if isOwner(resource.data.user_id) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Partners collection
    match /partners/{partnerId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == partnerId ||
        isPartnerOrAdmin()
      );
      allow create: if isPartnerOrAdmin() && hasValidPartnerAssignments(request.resource.data);
      allow update: if isPartnerOrAdmin() && hasValidPartnerAssignments(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    // Organization capacity metrics
    match /organization_capacity_metrics/{metricId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Organization capacity alerts
    match /organization_capacity_alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Invitations collection
    match /invitations/{invitationId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Checklists collection
    match /checklists/{checklistId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    // Week advancement log
    match /week_advancement_log/{logId} {
      allow read: if isPartnerOrAdmin();
      allow create: if isPartnerOrAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // Weekly points collection (legacy)
    match /weekly_points/{docId} {
      allow get: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid ||
        isPartnerOrAdmin()
      );
      allow list: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        resource.data.user_id == request.auth.uid
      );
      allow create, update: if isAuthenticated() && (
        request.resource.data.user_id == request.auth.uid ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Weekly points subcollection (canonical under profile docs)
    match /profiles/{userId}/weekly_points/{docId} {
      allow get: if isAuthenticated() && (
        userId == request.auth.uid ||
        isPartnerOrAdmin()
      );
      allow list: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        userId == request.auth.uid
      );
      allow create, update: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        (
          userId == request.auth.uid &&
          request.resource.data.user_id == request.auth.uid
        )
      );
      allow delete: if isSuperAdmin();
    }

    // User points collection (legacy)
    match /user_points/{docId} {
      allow get: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isPartnerOrAdmin()
      );
      allow list: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        resource.data.userId == request.auth.uid
      );
      allow create, update: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Journeys collection
    match /journeys/{journeyId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Weekly activities subcollection
    match /profiles/{userId}/weeklyActivities/{activityId} {
      allow read: if isAuthenticated() && (
        userId == request.auth.uid ||
        isPartnerOrAdmin()
      );
      allow create, update: if isAuthenticated() && (
        userId == request.auth.uid ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Approvals collection
    match /approvals/{approvalId} {
      // Allow owner doc-id lookups for transaction-based request submission flows.
      allow get: if isAuthenticated() && (
        approvalId.matches(request.auth.uid + '__.*') ||
        resource.data.userId == request.auth.uid ||
        isPartnerOrAdmin()
      );
      allow list: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if (
        isPartnerOrAdmin() && (
          resource.data.userId != request.auth.uid || isSuperAdmin()
        )
      ) || (
        isAuthenticated() &&
        approvalId.matches(request.auth.uid + '__w.*') &&
        resource.data.type == 'points_verification' &&
        request.resource.data.type == 'points_verification' &&
        request.auth.uid == resource.data.userId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.status == 'pending'
      );
      allow delete: if isSuperAdmin();
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create, update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Per-user announcement state
    match /announcementStates/{userId}/states/{stateId} {
      allow read, create, update, delete: if isAuthenticated() && (
        request.auth.uid == userId ||
        isPartnerOrAdmin()
      );
    }

    // Automation rules
    match /automation_rules/{ruleId} {
      allow read, create, update, delete: if isPartnerOrAdmin();
    }

    // Book club visit analytics
    match /bookClubVisits/{visitId} {
      allow read: if isPartnerOrAdmin();
      allow create: if isAuthenticated() && (
        !('userId' in request.resource.data) ||
        request.resource.data.userId == null ||
        request.resource.data.userId == request.auth.uid
      );
      allow update, delete: if isSuperAdmin();
    }

    // Notification preferences
    match /notification_preferences/{userId} {
      allow read, create, update, delete: if isAuthenticated() && (
        request.auth.uid == userId ||
        isPartnerOrAdmin()
      );
    }

    // Notification settings
    match /notification_settings/{userId} {
      allow read, create, update, delete: if isAuthenticated() && (
        request.auth.uid == userId ||
        isPartnerOrAdmin()
      );
    }

    // Learner status records
    match /learner_status/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isPartnerOrAdmin()
      );
      allow create, update: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        (
          request.auth.uid == userId &&
          (
            !('userId' in request.resource.data) ||
            request.resource.data.userId == request.auth.uid
          )
        )
      );
      allow delete: if isSuperAdmin();
    }

    // Learner status history
    match /learner_status_history/{entryId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(request.resource.data)
      );
      allow update, delete: if isSuperAdmin();
    }

    // Status alerts
    match /status_alerts/{alertId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(request.resource.data)
      );
      allow update: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow delete: if isSuperAdmin();
    }

    // Engagement metrics
    match /engagement_metrics/{metricId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(request.resource.data)
      );
      allow update: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow delete: if isSuperAdmin();
    }

    // Mentor notifications
    match /mentor_notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        resource.data.mentor_id == request.auth.uid ||
        resource.data.mentorId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        request.resource.data.mentor_id == request.auth.uid ||
        request.resource.data.mentorId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        resource.data.mentor_id == request.auth.uid ||
        resource.data.mentorId == request.auth.uid
      );
      allow delete: if isSuperAdmin();
    }

    // Mentor escalations
    match /mentor_escalations/{escalationId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data) ||
        isOrgScopedData(resource.data)
      );
      allow create, update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Nudge assignments
    match /nudge_assignments/{assignmentId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(request.resource.data)
      );
      allow update: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow delete: if isSuperAdmin();
    }

    // Nudge campaigns
    match /nudge_campaigns/{campaignId} {
      allow read, create, update, delete: if isPartnerOrAdmin();
    }

    // Nudge effectiveness records
    match /nudge_effectiveness/{recordId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(request.resource.data)
      );
      allow update, delete: if isPartnerOrAdmin();
    }

    // Nudge cooldown tracker
    match /nudge_cooldowns/{cooldownId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        cooldownId.matches(request.auth.uid + '__.*') ||
        isUserReferenced(resource.data)
      );
      allow create, update: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        cooldownId.matches(request.auth.uid + '__.*') ||
        isUserReferenced(request.resource.data)
      );
      allow delete: if isSuperAdmin();
    }

    // Nudge status transition audit
    match /nudge_status_transitions/{transitionId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(request.resource.data)
      );
      allow update, delete: if isSuperAdmin();
    }

    // Organization activity visibility cache
    match /organization_activity_visibility/{visibilityId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isOrgScopedData(resource.data)
      );
      allow create, update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Organization configuration
    match /organization_configuration/{orgId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isOrgMember(orgId)
      );
      allow create, update, delete: if isPartnerOrAdmin();
    }

    // Organization configuration change log
    match /organization_configuration/{orgId}/changes/{changeId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isOrgMember(orgId)
      );
      allow create, update, delete: if isPartnerOrAdmin();
    }

    // Organization leadership activity log
    match /organizations/{orgId}/leadership_activity/{activityId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isOrgMember(orgId)
      );
      allow create, update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Organization learner pass mark adjustments
    match /organizations/{orgId}/learner_pass_marks/{adjustmentId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(request.resource.data)
      );
      allow update: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow delete: if isSuperAdmin();
    }

    // Partner digest queue
    match /partner_daily_digest_queue/{digestId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        resource.data.partnerId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        request.resource.data.partnerId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        request.resource.data.partnerId == resource.data.partnerId &&
        (
          isPartnerOrAdmin() ||
          request.auth.uid == resource.data.partnerId
        )
      );
      allow delete: if isSuperAdmin();
    }

    // Partner digest schedules
    match /digest_schedules/{scheduleId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        resource.data.partnerId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        request.resource.data.partnerId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        resource.data.partnerId == request.auth.uid
      );
      allow delete: if isSuperAdmin();
    }

    // Pending organization deletions (recovery markers)
    match /pending_org_deletions/{markerId} {
      allow read, create, update, delete: if isSuperAdmin();
    }

    // Transformation partners lookup
    match /transformation_partners/{partnerId} {
      allow read: if isAuthenticated();
      allow create, update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Lift progress
    match /lift_progress/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isPartnerOrAdmin()
      );
      allow create, update: if isAuthenticated() && (
        request.auth.uid == userId ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Weekly aggregation (dashboard)
    match /weekly_aggregation/{docId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(request.resource.data)
      );
      allow update: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow delete: if isSuperAdmin();
    }

    // Weekly checklist (dashboard)
    match /weekly_checklist/{docId} {
      allow read: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow create: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(request.resource.data)
      );
      allow update: if isAuthenticated() && (
        isPartnerOrAdmin() ||
        isUserReferenced(resource.data)
      );
      allow delete: if isSuperAdmin();
    }

    // Leaderboard summary
    match /leaderboard_summary/{entryId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();
    }

    // FAQs
    match /faqs/{faqId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
