rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return isAuthenticated() && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('role', '')
        : '';
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }

    function isPartner() {
      return isAuthenticated() && getUserRole() == 'partner';
    }

    function isPartnerOrAdmin() {
      return isAuthenticated() && (getUserRole() == 'partner' || getUserRole() == 'super_admin');
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function getUserCompanyId() {
      return isAuthenticated() && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('companyId', '')
        : '';
    }

    function isValidPartnerAssignment(assignment) {
      return assignment is map
        && assignment.keys().hasOnly(['organizationId', 'companyCode', 'status'])
        && isNonEmptyString(assignment.organizationId)
        && isNonEmptyString(assignment.companyCode)
        && (!('status' in assignment) || assignment.status in ['active', 'watch', 'paused', 'inactive']);
    }

    function hasValidPartnerAssignments(data) {
      return !('assignedOrganizations' in data)
        || (data.assignedOrganizations is list
          && data.assignedOrganizations.all(assignment, isValidPartnerAssignment(assignment)));
    }

    function hasParticipantsList(data) {
      return data.keys().hasAll(['participants']) && data.participants is list;
    }

    function hasPeerSessionRequestFields(data) {
      return data.keys().hasAll(['fromUserId', 'toUserId']);
    }

    function isWeeklyMatchOwner(data) {
      return isAuthenticated() && data is map && (
        request.auth.uid == data.user_id ||
        request.auth.uid == data.userId
      );
    }

    function isWeeklyMatchParticipant(matchId) {
      return isAuthenticated() && (
        matchId.matches(request.auth.uid + '-.*') ||
        (resource != null && (
          request.auth.uid == resource.data.user_id ||
          request.auth.uid == resource.data.userId ||
          request.auth.uid == resource.data.user1_id ||
          request.auth.uid == resource.data.user2_id ||
          request.auth.uid == resource.data.peer_id ||
          request.auth.uid == resource.data.peerId
        ))
      );
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Profiles collection
    match /profiles/{userId} {
      allow read, write: if request.auth != null;
    }

    // Referral codes collection
    match /referralCodes/{codeId} {
      // Anyone can read to validate codes during signup
      allow read: if true;
      // Only authenticated users can create their own referral code
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid;
      // Only owner or admin can update
      allow update: if isOwner(request.resource.data.uid) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Referrals collection
    match /referrals/{referralId} {
      // Referrer can read their own referrals, referred user can read their own record
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.referrerUid ||
        request.auth.uid == resource.data.referredUid ||
        isPartnerOrAdmin()
      );
      // Only server (Cloud Functions) should create referrals
      // Client can create if the referredUid matches the auth user
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.referredUid;
      // Only Cloud Functions (via admin SDK) should update referrals
      // Restrict client-side updates
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Points ledger collection
    match /pointsLedger/{entryId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.uid ||
        isPartnerOrAdmin()
      );
      // Only server-side (Cloud Functions) or the owner can create
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.uid ||
        isPartnerOrAdmin()
      );
      // Only admins can update/delete ledger entries
      allow update, delete: if isPartnerOrAdmin();
    }

    // Weekly progress collection
    match /weeklyProgress/{progressId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (
        progressId.matches(request.auth.uid + '__.*') ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Window progress collection
    match /windowProgress/{progressId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (
        progressId.matches(request.auth.uid + '__.*') ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Points transactions collection (for leaderboards)
    match /points_transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isPartnerOrAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.user_id;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.user_id;
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isSuperAdmin()
      );
    }

    // Weekly target alerts
    match /weekly_target_alerts/{alertId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Organizations collection
    match /organizations/{orgId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isPartnerOrAdmin();
    }

    // Points verification requests
    match /points_verification_requests/{requestId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Upgrade requests
    match /upgrade_requests/{requestId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Admin notifications
    match /admin_notifications/{notificationId} {
      allow read: if isPartnerOrAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    // Villages collection
    match /villages/{villageId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isPartnerOrAdmin();
    }

    // Clusters collection
    match /clusters/{clusterId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isPartnerOrAdmin();
    }

    // Challenges collection
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.participants ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Peer matching collections
    match /peer_weekly_matches/{matchId} {
      allow read: if isWeeklyMatchParticipant(matchId) || isPartnerOrAdmin();
      allow create: if isWeeklyMatchOwner(request.resource.data);
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.user1_id ||
        request.auth.uid == resource.data.user2_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.user_id ||
        request.auth.uid == request.resource.data.userId
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.user1_id ||
        request.auth.uid == resource.data.user2_id ||
        request.auth.uid == resource.data.peer_id ||
        request.auth.uid == resource.data.peerId ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Peer sessions
    match /peer_sessions/{sessionId} {
      allow read: if isAuthenticated() && (
        (hasParticipantsList(resource.data) && request.auth.uid in resource.data.participants) ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (hasParticipantsList(resource.data) && request.auth.uid in resource.data.participants) ||
        isPartnerOrAdmin()
      );
      allow delete: if isPartnerOrAdmin();
    }

    // Peer session requests/invitations
    match /peer_session_requests/{requestId} {
      allow read: if isAuthenticated() && (
        (hasPeerSessionRequestFields(resource.data) && (
          request.auth.uid == resource.data.fromUserId ||
          request.auth.uid == resource.data.toUserId
        )) ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.fromUserId;
      allow update: if isAuthenticated() && (
        (hasPeerSessionRequestFields(resource.data) && (
          request.auth.uid == resource.data.fromUserId ||
          request.auth.uid == resource.data.toUserId
        )) ||
        isPartnerOrAdmin()
      );
      allow delete: if isPartnerOrAdmin();
    }

    // Support assignments
    match /support_assignments/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isPartnerOrAdmin()
      );
      allow create, update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Peer matches
    match /peer_matches/{matchId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Weekly habits
    match /weekly_habits/{habitId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Inspiration quotes
    match /inspiration_quotes/{quoteId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Impact logs collection
    match /impact_logs/{logId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        (resource.data.companyId is string && resource.data.companyId == getUserCompanyId()) ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.user_id ||
        request.auth.uid == request.resource.data.userId ||
        isPartnerOrAdmin()
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        isPartnerOrAdmin()
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.userId ||
        isSuperAdmin()
      );
    }

    // Badges collection
    match /badges/{badgeId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // User badges collection (camelCase)
    match /userBadges/{badgeAwardId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // User badges collection (snake_case)
    match /user_badges/{badgeAwardId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // Courses collection
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();
    }

    // Organization courses collection
    match /organization_courses/{courseId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isPartnerOrAdmin();
    }

    // Nudge templates
    match /nudge_templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Nudges sent
    match /nudges_sent/{nudgeId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isPartnerOrAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // Journey configs
    match /journey_configs/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Activity catalog
    match /activity_catalog/{activityId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Events collection
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // User courses collection
    match /user_courses/{courseId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.user_id ||
        isPartnerOrAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // System health alerts
    match /system_health_alerts/{alertId} {
      allow read: if isPartnerOrAdmin();
      allow write: if isSuperAdmin();
    }

    // Task notifications
    match /task_notifications/{taskId} {
      allow read: if isPartnerOrAdmin();
      allow write: if isSuperAdmin();
    }

    // Admin activity log
    match /admin_activity_log/{entryId} {
      allow read: if isPartnerOrAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    // Points verifications collection
    match /points_verifications/{verificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    // Points verification requests collection
    match /points_verification_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Partner organizations collection
    match /partner_organizations/{partnerOrgId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Registrations collection
    match /registrations/{registrationId} {
      allow read: if isAuthenticated();
      allow create: if true;  // Allow during signup
      allow update: if isOwner(resource.data.user_id) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Partners collection
    match /partners/{partnerId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == partnerId ||
        isPartnerOrAdmin()
      );
      allow create: if isPartnerOrAdmin() && hasValidPartnerAssignments(request.resource.data);
      allow update: if isPartnerOrAdmin() && hasValidPartnerAssignments(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    // Organization capacity metrics
    match /organization_capacity_metrics/{metricId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Organization capacity alerts
    match /organization_capacity_alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Invitations collection
    match /invitations/{invitationId} {
      allow read: if isAuthenticated();
      allow create: if isPartnerOrAdmin();
      allow update: if isPartnerOrAdmin();
      allow delete: if isSuperAdmin();
    }

    // Checklists collection
    match /checklists/{checklistId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
